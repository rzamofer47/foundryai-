{
  "name": "foundryai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev.cjs",
    "dev:3050": "next dev -p 3050 -H 127.0.0.1",
    "dev:3020": "next dev -p 3020 -H 127.0.0.1",
    "dev:3010": "next dev -p 3010 -H 127.0.0.1",
    "clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true}); console.log('Removed .next — run npm run dev again')\"",
    "dev:reset-cache": "node -e \"require('fs').rmSync(require('path').join('.next','cache'),{recursive:true,force:true}); console.log('Cleared .next/cache')\"",
    "build": "next build",
    "start": "next start -p 3050 -H 127.0.0.1"
  },
  "dependencies": {
    "next": "14.2.5",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.5.0",
    "framer-motion": "^12.38.0",
    "postcss": "^8.5.13",
    "tailwindcss": "^3.4.17",
    "typescript": "^5"
  }
}
